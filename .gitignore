# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# -----------------------------------
# Dependencies & Package Managers
# -----------------------------------
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.pnpm-debug.log*

# -----------------------------------
# Build & Output
# -----------------------------------
/.next/
out/
build/
dist/
.cache/

# -----------------------------------
# Testing & Coverage
# -----------------------------------
/coverage
/test-results
jest-html-reporters-*.html

# -----------------------------------
# Environment Variables
# -----------------------------------
.env
.env.*
.env.local
.env.development
.env.production
.env.test
*.env
*.local
*.secret
*.pem

# -----------------------------------
# Vercel
# -----------------------------------
.vercel/

# -----------------------------------
# Docker
# -----------------------------------
docker-compose.override.yml
Dockerfile.dev
*.pid
*.seed

# -----------------------------------
# Certbot (Let's Encrypt)
# -----------------------------------
certbot/conf/
certbot/www/

# -----------------------------------
# MongoDB / Redis Volumes
# -----------------------------------
mongodb-data/
redis-data/

# -----------------------------------
# NGINX Temp & Cache
# -----------------------------------
nginx/.cache/
nginx/.ssl/
nginx/conf.d/.temp/

# -----------------------------------
# Public Uploads (Optional Runtime)
# -----------------------------------
public/uploads/
public/tmp/

# -----------------------------------
# Logs
# -----------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------------
# System Files
# -----------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*.bak
*.tmp

# -----------------------------------
# TypeScript (Optional)
# -----------------------------------
*.tsbuildinfo
next-env.d.ts

# -----------------------------------
# IDE / Editor / OS Specific
# -----------------------------------
.vscode/
.idea/
*.iml

# -----------------------------------
# Misc
# -----------------------------------
*.tgz
*.gz
*.zip
